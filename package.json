{
  "name": "rollcasters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "test:effect-runtime": "tsc scripts/effect-runtime-tests.ts src/lib/game.ts src/lib/types.ts --outDir /tmp/rollcasters-effect-runtime-tests --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck && node /tmp/rollcasters-effect-runtime-tests/scripts/effect-runtime-tests.js",
    "test:dungeons:db": "node scripts/dungeon-runtime-db-tests.mjs",
    "test:dungeons:browser": "RUN_LIVE_DUNGEON_BROWSER_TEST=true node scripts/dungeon-combat-playwright.mjs",
    "test:effect-ui": "node scripts/effect-ui-tests.mjs",
    "test:effect-browser": "RUN_LIVE_EFFECT_BROWSER_TEST=true node scripts/effect-combat-playwright.mjs",
    "test:collection-layout": "node scripts/collection-layout-tests.mjs",
    "test:home-loadout-layout": "node scripts/home-loadout-layout-tests.mjs",
    "test:skill-equip-layout": "node scripts/skill-equip-layout-tests.mjs",
    "test:responsive-shell-layout": "node scripts/responsive-shell-layout-tests.mjs",
    "test:collection-ui": "tsc scripts/collection-ui-logic-tests.ts src/lib/loadout.ts src/lib/progression.ts src/lib/game.ts src/lib/effects.ts src/lib/types.ts --outDir /tmp/rollcasters-collection-ui-tests --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck && node /tmp/rollcasters-collection-ui-tests/scripts/collection-ui-logic-tests.js",
    "test:collectibles-shop": "tsc scripts/collectibles-shop-tests.ts src/lib/collectibles.ts src/lib/types.ts --outDir /tmp/rollcasters-collectibles-shop-tests --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck && node /tmp/rollcasters-collectibles-shop-tests/scripts/collectibles-shop-tests.js",
    "test:collectibles-shop:db": "node scripts/collectibles-shop-db-tests.mjs",
    "test:collectibles-shop:browser": "RUN_LIVE_COLLECTIBLES_BROWSER_TEST=true node scripts/collectibles-shop-playwright.mjs",
    "test:gate-challenges:db": "node scripts/gate-challenges-db-tests.mjs",
    "test:gate-challenges:browser": "RUN_LIVE_GATE_CHALLENGE_BROWSER_TEST=true node scripts/gate-challenges-playwright.mjs",
    "test:starter-selection:db": "node scripts/starter-selection-db-tests.mjs",
    "test:progression-points:db": "node scripts/progression-point-rewards-db-tests.mjs",
    "test:progression-points:browser": "RUN_LIVE_PROGRESSION_POINTS_TEST=true node scripts/progression-point-rewards-playwright.mjs",
    "test:point-unlocks:db": "node scripts/skill-ability-unlock-db-tests.mjs",
    "test:point-unlocks:browser": "RUN_LIVE_POINT_UNLOCK_TEST=true node scripts/skill-ability-unlock-playwright.mjs",
    "test:two-critter-elements:db": "node scripts/two-critter-elements-db-tests.mjs",
    "test:two-critter-elements:browser": "RUN_LIVE_TWO_CRITTER_ELEMENTS_TEST=true node scripts/two-critter-elements-playwright.mjs",
    "test:starter-selection:browser": "RUN_LIVE_STARTER_SELECTION_TEST=true node scripts/starter-selection-playwright.mjs",
    "test:collection-interaction-ui": "node scripts/collection-interaction-ui-tests.mjs",
    "test:sprite-containment": "node scripts/sprite-containment-tests.mjs",
    "test:collectible-commands": "node scripts/manage-user-collectible-tests.mjs",
    "test:collectible-commands:live": "RUN_LIVE_COLLECTIBLE_COMMAND_TEST=true node scripts/manage-user-collectible-live-test.mjs",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "db:migrate:dry": "node scripts/apply-migrations.mjs --dry-run",
    "db:migrate:file": "node scripts/apply-migrations.mjs --files",
    "db:delete-user": "node scripts/delete-dev-user.mjs",
    "game:grant:relic": "node scripts/manage-user-collectible.mjs grant relic",
    "game:grant:critter": "node scripts/manage-user-collectible.mjs grant critter",
    "game:grant:rollcaster": "node scripts/manage-user-collectible.mjs grant rollcaster",
    "game:revoke:relic": "node scripts/manage-user-collectible.mjs revoke relic",
    "game:revoke:critter": "node scripts/manage-user-collectible.mjs revoke critter",
    "game:revoke:rollcaster": "node scripts/manage-user-collectible.mjs revoke rollcaster",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "pg": "^8.13.1",
    "playwright": "^1.61.1"
  }
}
