VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# The player app consumes an immutable catalog and optimized artwork from the
# public game-releases bucket. Source/master artwork remains in game-assets for
# authoring and immutable promo-history fallback only.
VITE_GAME_CATALOG_MODE=release
VITE_GAME_PLAYER_BOOTSTRAP_MODE=v1
VITE_GAME_CATALOG_BASE_URL=https://YOUR_PROJECT_ID.supabase.co/storage/v1/object/public/game-releases/game-data
VITE_GAME_ASSET_BASE_URL=https://YOUR_PROJECT_ID.supabase.co/storage/v1/object/public/game-releases/game-assets
VITE_GAME_VERSION=0.1.0

# Optional local game-account credentials for developer-run browser tooling.
# These are not bundled into the Vite client and must never identify a
# `dev_tool_users` account.
GAME_ACCOUNT_EMAIL=your-game-account@example.com
GAME_ACCOUNT_PASSWORD=your-local-game-password

# Optional emergency fallbacks. Leave disabled during normal operation.
# VITE_ALLOW_LIVE_CATALOG_FALLBACK=true
# VITE_ALLOW_LEGACY_PLAYER_BOOTSTRAP=true

# Required for `db:delete-user` and all `game:grant:*` / `game:revoke:*` commands.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
DEV_ENABLE_USER_DELETE=false

# Optional for local direct database migrations or `db:delete-user -- --direct-db`.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
SUPABASE_DB_CA_CERT_PATH=certs/prod-ca-2021.crt
postgres_password=YOUR_DATABASE_PASSWORD

# Server-only compatibility publisher settings. The Content Studio is the normal
# production publisher, but the Game CLI accepts the same Supabase S3 contract.
RELEASE_STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_S3_ENDPOINT=https://YOUR_PROJECT_ID.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_S3_REGION=local
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=YOUR_STORAGE_S3_ACCESS_KEY_ID
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=YOUR_STORAGE_S3_SECRET_ACCESS_KEY
SUPABASE_RELEASE_BUCKET=game-releases

# Optional Cloudflare R2 publisher credentials. Set the provider to r2 to use it.
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_BUCKET=rollcasters-public
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# Local Supabase only. Never disable TLS for a remote database.
# SUPABASE_DB_SSL=false
